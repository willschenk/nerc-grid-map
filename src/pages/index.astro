---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../lib/nerc/map/nerc-org-map.css";
import { ROLE_FULL_NAMES, ROLE_TIER, ROLE_WEIGHTS } from "../lib/nerc/roles.mjs";
import { roleSetColor } from "../lib/nerc/enrich.mjs";

const roleOrder = Object.keys(ROLE_WEIGHTS);
const tierNames: Record<number, string> = {
  1: "Grid authority",
  2: "Planning & coordination",
  3: "Asset, load & market",
};
const roleRows = roleOrder.map((tag) => ({
  tag,
  name: ROLE_FULL_NAMES[tag],
  weight: ROLE_WEIGHTS[tag],
  tier: ROLE_TIER[tag],
  color: roleSetColor([tag]),
}));
const tiers = [1, 2, 3].map((t) => ({
  tier: t,
  name: tierNames[t],
  roles: roleRows.filter((r) => r.tier === t),
}));
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="NERC Grid Map" wide>
  <link slot="head" rel="preload" as="fetch" href={`${base}nerc/orgs-render.json`} crossorigin />
  <link slot="head" rel="preload" as="fetch" href={`${base}nerc/states-10m.json`} crossorigin />
  <link slot="head" rel="preload" as="fetch" href={`${base}nerc/canada-land.json`} crossorigin />
  <div id="nerc-app">
    <div class="nerc-map-shell" data-nerc-map>
      <section class="nerc-stage" aria-label="NERC organization map">
        <svg id="nerc-svg" viewBox="0 0 960 600" role="img" aria-label="Map of NERC-registered organizations across the United States"></svg>
        <div id="nerc-loading" class="nerc-loading">Loading map...</div>
        <div id="nerc-tooltip" class="nerc-tooltip" hidden></div>
        <div id="nerc-tour-status" class="nerc-tour-status" hidden></div>

        <header class="nerc-topbar" aria-label="Map controls and summary">
          <div class="nerc-brand">
            <h1>NERC Grid Map</h1>
          </div>

          <div class="nerc-map-actions" aria-label="Map actions">
            <button id="nerc-metrics-toggle" type="button" class="nerc-icon-btn nerc-letter-button" aria-label="Map metrics" title="Map metrics">M</button>
            <button id="nerc-info-toggle" type="button" class="nerc-icon-btn nerc-info-button" aria-label="How to read this map" title="How to read this map">i</button>
            <button id="nerc-play-tour" type="button" class="nerc-action-btn nerc-play-btn" aria-label="Play walkthrough">&#9654; Tour</button>
          </div>
        </header>

        <button id="nerc-tour-fab" type="button" class="nerc-tour-fab" aria-label="Play walkthrough">&#9654; Tour</button>

        <div class="nerc-zoom-controls" role="group" aria-label="Zoom controls">
          <button id="nerc-zoom-in" type="button" class="nerc-zoom-btn" aria-label="Zoom in to reveal more organizations" title="Zoom in">+</button>
          <button id="nerc-zoom-out" type="button" class="nerc-zoom-btn" aria-label="Zoom out" title="Zoom out">&#8722;</button>
          <button id="nerc-zoom-home" type="button" class="nerc-zoom-btn nerc-zoom-home" aria-label="Reset to national view" title="Reset view">&#8962;</button>
        </div>

        <aside id="nerc-metrics-panel" class="nerc-popover nerc-metrics-panel" hidden>
          <button id="nerc-metrics-close" type="button" class="nerc-panel-close" aria-label="Close metrics">&times;</button>
          <h2>Dataset summary</h2>
          <div class="nerc-metrics-body" id="nerc-metrics-body" aria-label="Map summary"></div>
        </aside>

        <aside id="nerc-panel" class="nerc-panel" hidden>
          <div id="nerc-panel-body"></div>
        </aside>

        <aside id="nerc-info-panel" class="nerc-popover nerc-info-panel" hidden>
          <button id="nerc-info-close" type="button" class="nerc-panel-close" aria-label="Close">&times;</button>
          <h2>How to read it</h2>
          <p class="nerc-info-lead">Each dot is one organization, at its headquarters.</p>
          <p class="nerc-info-legend"><b>Color</b> role mix <span aria-hidden="true">&middot;</span> <b>Size</b> role weight <span aria-hidden="true">&middot;</span> <b>Dotted</b> no NERC ID</p>
          <div class="nerc-legend-examples" aria-label="How to read a dot">
            <div class="nerc-legend-row">
              <span class="nerc-legend-swatch nerc-legend-size">
                <span class="nerc-legend-dot nerc-legend-dot-lg"></span>
                <span class="nerc-legend-dot nerc-legend-dot-sm"></span>
              </span>
              <span class="nerc-legend-text"><b>Bigger dot</b> = more reliability roles (a grid authority); <b>smaller dot</b> = a single-role entity.</span>
            </div>
            <div class="nerc-legend-row">
              <span class="nerc-legend-swatch">
                <span class="nerc-legend-dot" style="--c:hsl(210, 70%, 52%)"></span>
                <span class="nerc-legend-dot" style="--c:hsl(140, 55%, 45%)"></span>
                <span class="nerc-legend-dot" style="--c:hsl(28, 80%, 55%)"></span>
              </span>
              <span class="nerc-legend-text"><b>Color</b> shows the mix of roles — see the abbreviations below.</span>
            </div>
            <div class="nerc-legend-row">
              <span class="nerc-legend-swatch">
                <span class="nerc-legend-dot nerc-legend-dot-dotted"></span>
              </span>
              <span class="nerc-legend-text"><b>Dotted outline</b> = not in the NERC registry (no NERC ID).</span>
            </div>
          </div>
          <details class="nerc-role-guide" open>
            <summary>Role abbreviations</summary>
            <div class="nerc-role-guide-grid">
              {
                tiers.map((t) => (
                  <section class="nerc-role-group" aria-label={t.name}>
                    <h2>{t.name}</h2>
                    <div class="nerc-role-defs">
                      {t.roles.map((r) => (
                        <span class="nerc-role-def" data-role={r.tag} style={`--c:${r.color}`} title={r.name}>
                          <span class="nerc-dot" />
                          <strong>{r.tag}</strong>
                          <span>{r.name}</span>
                        </span>
                      ))}
                    </div>
                  </section>
                ))
              }
            </div>
          </details>
          <p class="nerc-info-source">Source: NERC Active Compliance Registry Matrix (Functions)</p>
        </aside>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  import { mountNercOrgMap } from "../lib/nerc/map/nerc-org-map";

  mountNercOrgMap();
</script>
