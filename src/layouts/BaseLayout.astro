---
import "../styles/base.css";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const {
  title,
  description = "Interactive map of NERC-registered electric grid organizations by functional role.",
  wide = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <slot name="head" />
  </head>
  <body>
    <main class={wide ? "main-wide" : undefined}>
      <slot />
    </main>
  </body>
</html>
